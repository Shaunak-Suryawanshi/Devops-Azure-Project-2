pipeline {
    agent any

    environment {
        IMAGE_NAME = "incident-platform"
        CONTAINER_NAME = "incident-platform-ci"
        APP_PORT = "1001"
        MONGODB_DB_NAME = "${env.MONGODB_DB_NAME ?: 'incident_platform'}"
        REDIS_HOST = "${env.REDIS_HOST ?: 'localhost'}"
        REDIS_PORT = "${env.REDIS_PORT ?: '6379'}"
        REDIS_DB = "${env.REDIS_DB ?: '0'}"
        REDIS_USERNAME = "${env.REDIS_USERNAME ?: ''}"
        REDIS_PASSWORD = "${env.REDIS_PASSWORD ?: ''}"
        REDIS_SSL = "${env.REDIS_SSL ?: 'false'}"
        RATE_LIMIT_REQUESTS = "${env.RATE_LIMIT_REQUESTS ?: '30'}"
        RATE_LIMIT_WINDOW_SECONDS = "${env.RATE_LIMIT_WINDOW_SECONDS ?: '60'}"
    }

    stages {
        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Docker Version Check') {
            steps {
                bat 'docker --version'
            }
        }

        stage('Validate Required Environment') {
            steps {
                script {
                    if (!env.MONGODB_URI?.trim()) {
                        error("MONGODB_URI is missing. Set it in Jenkins job/global environment before running.")
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'docker build -f infra/docker/app/Dockerfile -t %IMAGE_NAME%:%BUILD_NUMBER% -t %IMAGE_NAME%:latest .'
            }
        }

        stage('Stop Old Container') {
            steps {
                bat 'docker rm -f %CONTAINER_NAME% || exit /b 0'
                bat "powershell -Command \"\$ids = docker ps -q --filter 'publish=%APP_PORT%'; if (\$ids) { \$ids | ForEach-Object { docker rm -f \$_ } }\""
            }
        }

        stage('Run New Container') {
            steps {
                bat '''docker run -d --name %CONTAINER_NAME% -p %APP_PORT%:1000 ^
                -e MONGODB_URI="%MONGODB_URI%" ^
                -e MONGODB_DB_NAME="%MONGODB_DB_NAME%" ^
                -e REDIS_HOST="%REDIS_HOST%" ^
                -e REDIS_PORT="%REDIS_PORT%" ^
                -e REDIS_DB="%REDIS_DB%" ^
                -e REDIS_USERNAME="%REDIS_USERNAME%" ^
                -e REDIS_PASSWORD="%REDIS_PASSWORD%" ^
                -e REDIS_SSL="%REDIS_SSL%" ^
                -e RATE_LIMIT_REQUESTS="%RATE_LIMIT_REQUESTS%" ^
                -e RATE_LIMIT_WINDOW_SECONDS="%RATE_LIMIT_WINDOW_SECONDS%" ^
                %IMAGE_NAME%:%BUILD_NUMBER%'''
            }
        }

        stage('Smoke Test') {
            steps {
                bat 'powershell -Command "Start-Sleep -Seconds 8; Invoke-RestMethod -Method Get -Uri http://127.0.0.1:%APP_PORT%/health | ConvertTo-Json"'
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully. New container is running.'
        }
        failure {
            bat 'docker logs %CONTAINER_NAME% || exit /b 0'
            echo 'Pipeline failed. Check logs above.'
        }
    }
}
